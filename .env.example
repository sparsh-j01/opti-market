# Backend env vars. Copy to .env for local dev (gitignored).
# In production, set these in your hosting provider's dashboard
# (Render → Environment, Railway → Variables, Fly.io → secrets).

# Comma-separated list of frontend origins allowed to call this API.
# Local dev default works without setting this var.
# Production example:
#   ALLOWED_ORIGINS=https://opti-market.vercel.app,https://www.your-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
