# Node
node_modules/
.next/
out/

# Vendored Pyodide runtime IS committed: Vercel's Next builder doesn't run
# our vendor step reliably, so the build-time-only approach 404'd in prod.
# Committing the pruned runtime (~41 MB) guarantees it ships. The vendor
# script still regenerates it locally/CI and skips when the marker exists.
frontend/pyodide-*.tar.bz2

# Playwright
test-results/
playwright-report/

# NOTE: frontend/public/py and frontend/public/data ARE committed — Vercel's
# Node build has no Python to regenerate them; the refresh-data Action keeps
# them in sync. Root copies remain the canonical source of truth.

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Environment — NEVER commit API keys or secrets
.env
.env.local
.env.*.local

# Cache
market_data.csv

# Sample files (not part of the project)
*.pdf

# Presentation & Report (local only)
presentation.html
report.html
report.docx
ppt_content.md

# Gemini
.gemini/

# Local tooling state — session state, agent/skill installs, lockfiles
# (never commit: third-party tooling metadata, not project source)
.gstack/
.agents/
skills-lock.json

# Planning docs (local only)
plan.md
claude.md
design.md

